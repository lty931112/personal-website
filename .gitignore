# ============================================
# Git 忽略文件配置
# 定义不应纳入版本控制的文件和目录
# ============================================

# ------------------------------------------
# IDE 和编辑器配置文件
# ------------------------------------------
.idea/                    # JetBrains 系列 IDE（IntelliJ IDEA、WebStorm 等）
.vscode/                  # Visual Studio Code
*.iml                     # IntelliJ IDEA 模块文件
*.iws                     # IntelliJ IDEA 工作区文件
*.ipr                     # IntelliJ IDEA 项目文件
*.suo                     # Visual Studio 用户选项
*.ntvs*                   # Visual Studio Code
*.njsproj                 # Visual Studio Node.js 项目
*.sln                     # Visual Studio 解决方案
*.sw?                     # Vim 交换文件
*.swp                     # Vim 交换文件
*~                        # Linux 编辑器备份文件

# ------------------------------------------
# 操作系统生成文件
# ------------------------------------------
.DS_Store                 # macOS 目录元数据
.DS_Store?                # macOS 目录元数据（变体）
._*                       # macOS 资源分支文件
.Spotlight-V100           # macOS Spotlight 索引
.Trashes                  # macOS 废纸篓
ehthumbs.db               # Windows 缩略图缓存
Thumbs.db                 # Windows 缩略图缓存
Desktop.ini               # Windows 文件夹配置

# ------------------------------------------
# 环境变量和配置文件
# 包含敏感信息，不应提交到版本控制
# ------------------------------------------
.env                      # 通用环境变量文件
.env.local                # 本地环境变量
.env.*.local              # 特定环境的环境变量（如 .env.development.local）
.env.development          # 开发环境变量
.env.production           # 生产环境变量
.env.test                 # 测试环境变量
*.local                   # 所有本地配置文件

# ------------------------------------------
# 前端构建输出
# ------------------------------------------
dist/                     # 通用构建输出目录
build/                    # 构建输出目录
.next/                    # Next.js 构建输出
out/                      # Next.js 静态导出目录
.nuxt/                    # Nuxt.js 构建输出
.cache/                   # 构建缓存
*.tsbuildinfo             # TypeScript 增量编译信息

# ------------------------------------------
# 后端构建输出
# ------------------------------------------
target/                   # Maven 构建输出目录
*.class                   # Java 编译后的字节码
*.jar                     # Java JAR 包（排除源码中的可执行 JAR）
*.war                     # Java WAR 包
*.ear                     # Java EAR 包
*.log                     # 日志文件

# ------------------------------------------
# 依赖目录
# ------------------------------------------
node_modules/             # Node.js 依赖目录
bower_components/         # Bower 依赖目录

# ------------------------------------------
# 日志文件
# ------------------------------------------
*.log                     # 所有日志文件
logs/                     # 日志目录
npm-debug.log*            # npm 调试日志
yarn-debug.log*           # Yarn 调试日志
yarn-error.log*           # Yarn 错误日志
pnpm-debug.log*           # pnpm 调试日志

# ------------------------------------------
# 测试覆盖率报告
# ------------------------------------------
coverage/                 # 测试覆盖率目录
.nyc_output/              # NYC 覆盖率输出
*.lcov                    # 覆盖率报告文件

# ------------------------------------------
# Docker 相关
# ------------------------------------------
docker-compose.override.yml  # Docker Compose 覆盖配置（本地开发用）

# ------------------------------------------
# 其他
# ------------------------------------------
*.bak                     # 备份文件
*.tmp                     # 临时文件
*.temp                    # 临时文件
