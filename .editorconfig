# ============================================
# EditorConfig 编辑器配置
# 统一不同编辑器和 IDE 的代码风格
# 详见: https://editorconfig.org
# ============================================

# 根配置文件标识
root = true

# ------------------------------------------
# 全局默认配置
# 适用于所有文件类型
# ------------------------------------------
[*]
indent_style = space          # 使用空格缩进
indent_size = 2               # 缩进大小为 2 个空格
end_of_line = lf              # 使用 LF（Linux）换行符
charset = utf-8               # 使用 UTF-8 字符编码
trim_trailing_whitespace = true  # 自动删除行尾空格
insert_final_newline = true   # 文件末尾插入空行

# ------------------------------------------
# Java 文件配置
# Java 社区惯例使用 4 个空格缩进
# ------------------------------------------
[*.java]
indent_size = 4

# ------------------------------------------
# XML 文件配置
# ------------------------------------------
[*.xml]
indent_size = 4

# ------------------------------------------
# YAML 文件配置
# ------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ------------------------------------------
# Markdown 文件配置
# Markdown 中行尾双空格表示换行，不应删除
# ------------------------------------------
[*.md]
trim_trailing_whitespace = false

# ------------------------------------------
# Shell 脚本配置
# ------------------------------------------
[*.sh]
indent_size = 2

# ------------------------------------------
# Dockerfile 配置
# ------------------------------------------
[Dockerfile]
indent_size = 4

# ------------------------------------------
# Makefile 配置
# Makefile 必须使用 Tab 缩进
# ------------------------------------------
[Makefile]
indent_style = tab

# ------------------------------------------
# .gitignore 配置
# ------------------------------------------
[.gitignore]
indent_size = 2
